# ============================================================
# SBDMM Platform — Root .gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
.turbo/
out/

# Environment files — NEVER commit these
.env
.env.local
.env.vercel
.env.development.local
.env.test.local
.env.staging.local
.env.production.local
.env.*.local

# Supabase local
supabase/.temp/
supabase/config.toml.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS artifacts
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/
*.lcov

# TypeScript
*.tsbuildinfo

# Secrets — belt-and-suspenders; secret scanning CI will also catch these
*.pem
*.key
*.p12
*.pfx
serviceAccountKey.json

# Playwright
playwright-report/
playwright-results.xml
test-results/
