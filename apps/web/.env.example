# ============================================================
# SBDMM Web App — Frontend Environment Variables
# ============================================================
# SECURITY RULES:
# 1. ONLY VITE_* variables are exposed to the browser.
# 2. NEVER put secrets, service role keys, or OpenAI keys here.
# 3. The SUPABASE_ANON_KEY is safe for the browser — it is a
#    public key restricted by RLS and your auth policies.
# 4. The API calls to OpenAI go through your Express backend only.
#
# Copy to .env.local and fill in your values.
# ============================================================

# Supabase — Public (safe for browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Backend API URL
VITE_API_BASE_URL=http://localhost:3001

# Google OAuth — Client ID is public (safe for browser).
# The Client Secret lives in Supabase Auth settings ONLY — never here.
VITE_GOOGLE_CLIENT_ID=871600319503-33im9efu166k91380t88jd4uaafrgfag.apps.googleusercontent.com

# App config
VITE_APP_NAME=SBDMM Platform
VITE_APP_ENV=development

# ─── Observability ────────────────────────────────────────────
# Sentry: obtain DSN from https://sentry.io → Project → Settings → Client Keys
# Leave empty to disable Sentry in this environment
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# Float 0.0–1.0 — fraction of page loads traced (0.1 recommended for production)
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# Sentry source-map upload (CI / build machine only — NOT in browser)
# Generate a token at https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
VITE_SENTRY_ORG=your-sentry-org
VITE_SENTRY_PROJECT=sbdmm-web
# Git commit SHA or semantic version — set by CI
SENTRY_RELEASE=
VITE_APP_VERSION=0.0.0
