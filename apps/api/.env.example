# ============================================================
# SBDMM API — Environment Variables Template
# ============================================================
# COPY this file to .env.local and populate values.
# NEVER commit .env.local or any file with real values.
#
# SECURITY CONVENTION:
#   VITE_*        → Safe for browser (frontend only)
#   No prefix     → Server-only, never expose to client
#   *_SECRET      → Treat as highest sensitivity; never log
#   *_SERVICE_*   → Supabase service role — NEVER in browser
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ─── Allowed Origins (comma-separated) ───────────────────────
# SECURITY: List only exact origins. No wildcards in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Supabase (Server-Side) ───────────────────────────────────
# SECURITY: These are SERVER-ONLY. NEVER put in frontend code.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── Supabase (Public — safe to expose to frontend) ──────────
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── OpenAI (Server-Side ONLY) ────────────────────────────────
# SECURITY: NEVER expose this key to the browser. All AI calls
# go through our server-side proxy route.
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
OPENAI_ORG_ID=org-YOUR_ORG_ID

# AI governance controls
AI_MAX_TOKENS_PER_REQUEST=2048
AI_MAX_REQUESTS_PER_USER_PER_HOUR=50
AI_ALLOWED_MODELS=gpt-4o,gpt-4o-mini

# ─── JWT / Auth ───────────────────────────────────────────────
# Used to verify Supabase JWTs server-side
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AI_MAX_REQUESTS=20
# Max write operations per IP per window on sensitive routes (admin/compliance)
RATE_LIMIT_SENSITIVE_WRITE_MAX=30

# ─── Audit Log Security ────────────────────────────────────────
# GDPR/POPIA: IP addresses are HMAC-SHA256 hashed before storage.
# Generate with: openssl rand -hex 32
# HUMAN DECISION: Set this in your secret manager. Rotate on suspected compromise.
# WARNING: If this value changes, existing hashes in the DB become unresolvable (by design).
AUDIT_IP_HASH_SECRET=REPLACE_WITH_openssl_rand_-hex_32_output

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_REDACT_FIELDS=password,token,secret,apiKey,authorization,ssn,pan,cvv

# ─── Webhook Secrets ──────────────────────────────────────────
# HUMAN DECISION: Replace with real secrets per integration.
WEBHOOK_SECRET_LOGISTICS_PROVIDER=YOUR_WEBHOOK_SECRET_HERE

# ─── Internal API Key (inter-service) ─────────────────────────
# Used only for internal service-to-service calls if needed.
INTERNAL_API_KEY=YOUR_INTERNAL_API_KEY_HERE

# ─── Feature Flags ────────────────────────────────────────────
FEATURE_AI_ROUTE_OPTIMIZATION=false
FEATURE_PAYMENT_MODULE=false
FEATURE_CROSS_BORDER_DOCS=false

# ─── Observability ────────────────────────────────────────────
# Set TELEMETRY_ENABLED=false to disable all telemetry (useful for local/unit tests)
TELEMETRY_ENABLED=true
# Sentry: obtain DSN from https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Float 0.0–1.0 — fraction of transactions traced (0.2 recommended for production)
SENTRY_TRACES_SAMPLE_RATE=1.0
# OpenTelemetry: URL of your OTLP collector (e.g. Grafana Cloud, Honeycomb, local Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=sbdmm-api
